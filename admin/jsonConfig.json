{
  "i18n": true,
  "type": "panel",
  "items": {
    "email": {
      "type": "text",
      "label": "Blink Benutzername / E-Mail",
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "password": {
      "type": "password",
      "label": "Passwort",
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "pin": {
      "type": "password",
      "label": "PIN / 2FA-Code (optional)",
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "pollIntervalSec": {
      "type": "number",
      "label": "Status-Polling Intervall (Sek.)",
      "min": 15,
      "max": 3600,
      "default": 60,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "snapshotDir": {
      "type": "text",
      "label": "Snapshot-Verzeichnis",
      "default": "/opt/iobroker/iobroker-data/blinkpy",
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "liveSnapshotEnabled": {
      "type": "checkbox",
      "label": "Livebild per Snapshot aktivieren",
      "default": true,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "liveSnapshotIntervalSec": {
      "type": "number",
      "label": "Livebild Intervall (Sek.)",
      "min": 5,
      "max": 3600,
      "default": 10,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "storeBase64": {
      "type": "checkbox",
      "label": "Bild zusätzlich als Base64-Data-URL im State speichern",
      "default": true,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "cleanupOldSnapshots": {
      "type": "checkbox",
      "label": "Alte Snapshot-Dateien automatisch löschen",
      "default": true,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "maxSnapshotAgeHours": {
      "type": "number",
      "label": "Max. Alter Snapshot-Dateien (Stunden)",
      "min": 1,
      "max": 168,
      "default": 24,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "batteryWarningHeader": {
      "type": "staticText",
      "text": "Batteriewarnung per Pushover",
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 12
    },
    "batteryWarningEnabled": {
      "type": "checkbox",
      "label": "Batteriewarnung aktivieren",
      "default": false,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "batteryWarningThresholdVolt": {
      "type": "number",
      "label": "Grenzwert Batteriespannung (V)",
      "default": 1.1,
      "min": 0,
      "max": 5,
      "step": 0.01,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "batteryWarningPushoverInstance": {
      "type": "text",
      "label": "Pushover Instanz",
      "default": "pushover.0",
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "batteryWarningCooldownHours": {
      "type": "number",
      "label": "Warn-Cooldown pro Kamera (Stunden)",
      "default": 24,
      "min": 1,
      "max": 720,
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 6
    },
    "batteryWarningInfo": {
      "type": "staticText",
      "text": "Wenn status.battery_volt kleiner/gleich dem Grenzwert ist, wird pro Kamera höchstens einmal innerhalb des Cooldowns eine Pushover-Nachricht gesendet.",
      "sm": 12,
      "xs": 12,
      "lg": 4,
      "xl": 4,
      "md": 12
    }
  }
}